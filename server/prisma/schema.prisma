generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          Role     @default(USER)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  profile               UserProfile?
  refresh_tokens        RefreshToken[]
  triggers              UserTrigger[]
  routine_slots         RoutineSlot[]
  check_ins             CheckIn[]
  badges                UserBadge[]
  challenge_enrollments ChallengeEnrollment[]
  conflict_overrides    ConflictOverride[]
}

enum Role {
  USER
  ADMIN
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model UserProfile {
  id         String   @id @default(uuid())
  user_id    String   @unique
  skin_type  SkinType
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

enum SkinType {
  OILY
  DRY
  COMBINATION
  SENSITIVE
  ACNE_PRONE
  NORMAL
}

model Ingredient {
  id                   String               @id @default(uuid())
  inci_name            String               @unique
  common_name          String?
  functions            IngredientFunction[]
  comedogenic_rating   Int                  @default(0)
  irritation_potential IrritationLevel      @default(LOW)
  skin_type_flags      Json
  notes                String?
  is_active            Boolean              @default(true)
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  product_ingredients ProductIngredient[]
  user_triggers       UserTrigger[]
  conflict_rules_a    ConflictRule[]      @relation("IngredientA")
  conflict_rules_b    ConflictRule[]      @relation("IngredientB")
}

enum IrritationLevel {
  LOW
  MEDIUM
  HIGH
}

enum IngredientFunction {
  HUMECTANT
  EMOLLIENT
  EXFOLIANT
  ANTIOXIDANT
  PRESERVATIVE
  SURFACTANT
  EMULSIFIER
  FRAGRANCE
  COLORANT
  ACTIVE
  OTHER
}

model Product {
  id             String          @id @default(uuid())
  name           String
  brand          String
  category       ProductCategory
  description    String?
  image_url      String?
  skin_type_tags SkinType[]
  is_published   Boolean         @default(false)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  ingredients   ProductIngredient[]
  routine_slots RoutineSlot[]

  @@unique([name, brand])
}

enum ProductCategory {
  CLEANSER
  TONER
  SERUM
  MOISTURIZER
  SPF
  OIL
  EXFOLIANT
  EYE_CREAM
  MASK
}

model ProductIngredient {
  id            String @id @default(uuid())
  product_id    String
  ingredient_id String
  order_index   Int

  product    Product    @relation(fields: [product_id], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_id], references: [id])

  @@unique([product_id, ingredient_id])
  @@index([product_id])
}

model UserTrigger {
  id            String   @id @default(uuid())
  user_id       String
  ingredient_id String
  personal_note String?
  created_at    DateTime @default(now())

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredient_id], references: [id])

  @@unique([user_id, ingredient_id])
}

model RoutineSlot {
  id         String   @id @default(uuid())
  user_id    String
  product_id String
  slot       SlotType
  step_order Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])

  @@unique([user_id, product_id, slot])
  @@index([user_id, slot])
}

enum SlotType {
  AM
  PM
}

model ConflictRule {
  id               String        @id @default(uuid())
  rule_name        String
  ingredient_a_id  String
  ingredient_b_id  String
  conflict_scope   ConflictScope
  alert_type       AlertType
  severity         Severity
  explanation      String
  safe_to_override Boolean       @default(true)
  is_active        Boolean       @default(true)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  ingredientA Ingredient         @relation("IngredientA", fields: [ingredient_a_id], references: [id])
  ingredientB Ingredient         @relation("IngredientB", fields: [ingredient_b_id], references: [id])
  overrides   ConflictOverride[]

  @@unique([ingredient_a_id, ingredient_b_id, conflict_scope])
}

enum ConflictScope {
  SAME_SLOT
  ANY_SLOT
}

enum AlertType {
  HIGH_IRRITATION
  PH_CONFLICT
  OVERUSE
}

enum Severity {
  WARNING
  DANGER
}

model ConflictOverride {
  id            String   @id @default(uuid())
  user_id       String
  rule_id       String
  overridden_at DateTime @default(now())

  user User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rule ConflictRule @relation(fields: [rule_id], references: [id])

  @@unique([user_id, rule_id])
}

model CheckIn {
  id         String   @id @default(uuid())
  user_id    String
  slot       SlotType
  checked_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, slot])
}

model Badge {
  id          String    @id @default(uuid())
  name        String
  description String
  icon_url    String?
  milestone   Int
  slot        SlotType?
  created_at  DateTime  @default(now())

  user_badges UserBadge[]

  @@unique([name, slot])
}

model UserBadge {
  id        String   @id @default(uuid())
  user_id   String
  badge_id  String
  earned_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badge_id], references: [id])

  @@unique([user_id, badge_id])
}

model Challenge {
  id          String   @id @default(uuid())
  title       String
  description String
  start_date  DateTime
  end_date    DateTime
  goal_days   Int
  badge_icon  String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  enrollments ChallengeEnrollment[]
}

model ChallengeEnrollment {
  id           String   @id @default(uuid())
  user_id      String
  challenge_id String
  enrolled_at  DateTime @default(now())
  current_days Int      @default(0)
  completed    Boolean  @default(false)

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challenge_id], references: [id])

  @@unique([user_id, challenge_id])
}
